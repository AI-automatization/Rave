NODE_ENV=development
PORT=3007
MONGO_URI=mongodb://cinesync:cinesync_dev_pass@localhost:27017/cinesync_notification?authSource=admin
REDIS_URL=redis://:cinesync_redis_pass@localhost:6379
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@cinesync.app

# Logging
LOG_LEVEL=debug

# Internal service communication
INTERNAL_SECRET=your-internal-secret-key

# Telegram Bot (T-S063) — optional, bot disabled if not set
TELEGRAM_BOT_TOKEN=                        # BotFather → /newbot → token
TELEGRAM_BOT_USERNAME=RaveBot             # bot username without @
TELEGRAM_WEBHOOK_SECRET=                   # random string to verify webhook requests
TELEGRAM_WEBHOOK_URL=https://notification-production-9c30.up.railway.app/api/v1/notifications/telegram/webhook
APP_SCHEME=cinesync                        # mobile deep link scheme (cinesync://join/CODE)
WEB_BASE_URL=https://cinesync.app
