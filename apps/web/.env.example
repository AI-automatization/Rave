# CineSync — Web Client (.env.example)
# Nusxa ko'chiring: cp .env.example .env.local

# Public (brauzerda ko'rinadi)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3004
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Server-side only (Docker DNS yoki localhost)
AUTH_SERVICE_URL=http://auth:3001/api/v1/auth
USER_SERVICE_URL=http://user:3002/api/v1
CONTENT_SERVICE_URL=http://content:3003/api/v1
WATCH_PARTY_SERVICE_URL=http://watch-party:3004/api/v1

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_in_production

# Internal service communication
INTERNAL_SECRET=your-internal-secret-key
