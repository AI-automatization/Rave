{
  "expo": {
    "name": "CineSync",
    "slug": "cinesync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "cinesync",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cinesync.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Profil surati uchun",
        "NSPhotoLibraryUsageDescription": "Profil surati uchun",
        "NSMicrophoneUsageDescription": "Film ko'rish paytida audio uchun"
      }
    },
    "android": {
      "package": "com.cinesync.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0F",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E50914",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "expo-secure-store",
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
