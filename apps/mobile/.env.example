# ============================================================
# CineSync Mobile — Environment Variables template
# Nusxa ko'chirish: cp .env.example .env
# DIQQAT: .env faylini hech qachon git ga push qilma!
# ============================================================

# --- Backend API URLs (Railway production) ---
EXPO_PUBLIC_AUTH_URL=https://auth-production-47a8.up.railway.app/api/v1
EXPO_PUBLIC_USER_URL=https://user-production-86ed.up.railway.app/api/v1
EXPO_PUBLIC_CONTENT_URL=https://content-production-4e08.up.railway.app/api/v1
EXPO_PUBLIC_NOTIFICATION_URL=https://notification-production-9c30.up.railway.app/api/v1
EXPO_PUBLIC_WATCH_PARTY_URL=https://watch-part-production.up.railway.app
EXPO_PUBLIC_BATTLE_URL=https://battle-production-238a.up.railway.app/api/v1
EXPO_PUBLIC_ADMIN_URL=https://admin-production-8d2a.up.railway.app/api/v1

# --- Google OAuth ---
# Google Cloud Console → APIs & Services → Credentials
# Web Client ID (iOS va Expo Go uchun):
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android Client ID (Android uchun, SHA-1 fingerprint kerak):
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# --- Expo Push Notifications ---
# Expo Dashboard → Project → Project ID (UUID ko'rinishida)
EXPO_PUBLIC_PROJECT_ID=
